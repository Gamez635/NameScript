local function formatCFrame(cf)
    if not cf then return "CFrame.new(0,0,0)" end
    local x,y,z,r00,r01,r02,r10,r11,r12,r20,r21,r22 = cf:components()
    return string.format("CFrame.new(%.3f,%.3f,%.3f,%.6f,%.6f,%.6f,%.6f,%.6f,%.6f,%.6f,%.6f,%.6f)",
        x or 0, y or 0, z or 0, r00 or 1, r01 or 0, r02 or 0,
        r10 or 0, r11 or 0, r12 or 1, r20 or 0, r21 or 0, r22 or 0)
end

local function smoothCFrame(a, b, alpha)
    local pos = a.Position:Lerp(b.Position, alpha)
    local look = a.LookVector:Lerp(b.LookVector, alpha).Unit
    local up = a.UpVector:Lerp(b.UpVector, alpha).Unit
    local right = look:Cross(up).Unit
    up = right:Cross(look).Unit
    return CFrame.fromMatrix(pos, right, up)
end


createBtn("Export Combined (Coil Fixed - Exact Walk)", Color3.fromRGB(100, 255, 100), function(b)
    if #frames < 30 then
        b.Text = "Too few frames!"
        task.wait(1.5)
        b.Text = "Export Combined (Coil Fixed - Exact Walk)"
        return
    end

    b.Text = "Building... (" .. #frames .. "f)"
    progressLabel.Text = "Progress: 0%"

    task.spawn(function()
        local codeParts = {}
        table.insert(codeParts, [[
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local cam = workspace.CurrentCamera
local char = lp.Character or lp.CharacterAdded:Wait()
local hrp = char:WaitForChild("HumanoidRootPart")
local hum = char:WaitForChild("Humanoid")

local originalCamType = cam.CameraType
local originalAutoRotate = hum.AutoRotate
local originalWalkSpeed = hum.WalkSpeed
local originalHipHeight = hum.HipHeight

hum.AutoRotate = false
cam.CameraType = Enum.CameraType.Scriptable

local frames = {
]])

        local total = #frames
        for i, f in ipairs(frames) do
            local entry = string.format(
                "{Pos=Vector3.new(%.3f,%.3f,%.3f),Vel=Vector3.new(%.3f,%.3f,%.3f),Move=Vector3.new(%.3f,0,%.3f),CFrame=%s,hrpCFrame=%s,FOV=%.2f,Time=%.4f,WalkSpeed=%.2f}%s\n",
                f.Pos.X, f.Pos.Y, f.Pos.Z,
                f.Vel.X, f.Vel.Y, f.Vel.Z,
                f.Move.X, f.Move.Z,
                formatCFrame(f.CFrame),
                formatCFrame(f.hrpCFrame),
                f.FOV or 70,
                f.Time,
                f.WalkSpeed or 16,
                i < total and "," or ""
            )
            table.insert(codeParts, entry)
            if i % 200 == 0 then
                progressLabel.Text = "Progress: " .. math.floor((i / total) * 100) .. "%"
                task.wait()
            end
        end

        table.insert(codeParts, [[
}

local mode = "]] .. playbackMode .. [["
local t = 0
local idx = 1
local lastTime = frames[#frames].Time
local connection

local function smoothCFrame(a, b, alpha)
    local pos = a.Position:Lerp(b.Position, alpha)
    local look = a.LookVector:Lerp(b.LookVector, alpha).Unit
    local up = a.UpVector:Lerp(b.UpVector, alpha).Unit
    local right = look:Cross(up).Unit
    up = right:Cross(look).Unit
    return CFrame.fromMatrix(pos, right, up)
end

connection = RunService.RenderStepped:Connect(function(dt)
    t = t + dt
    if mode == "Once" and t > lastTime then
        cam.CameraType = originalCamType
        hum.AutoRotate = originalAutoRotate
        hum.WalkSpeed = originalWalkSpeed
        hum.HipHeight = originalHipHeight
        connection:Disconnect()
        return
    elseif mode == "Loop" then
        t = t % lastTime
    end

    while idx < #frames and t >= frames[idx + 1].Time do idx = idx + 1 end
    if idx >= #frames then idx = 1 end

    local a = frames[idx]
    local b = frames[idx + 1] or frames[1]
    local alpha = math.clamp((t - a.Time) / (b.Time - a.Time), 0, 1)

    local pos = a.Pos:Lerp(b.Pos, alpha)
    local move = a.Move:Lerp(b.Move, alpha)
    local fov = a.FOV + (b.FOV - a.FOV) * alpha
    local camCf = smoothCFrame(a.CFrame, b.CFrame, alpha)
    local charCf = a.hrpCFrame:Lerp(b.hrpCFrame or a.hrpCFrame, alpha)

    cam.CFrame = camCf
    cam.FieldOfView = fov

    hrp.CFrame = charCf
    hum.WalkSpeed = a.WalkSpeed
    hum.HipHeight = originalHipHeight

    hum:Move(move, true)
    hrp.AssemblyLinearVelocity = a.Vel:Lerp(b.Vel, alpha)
end)
]])

        local fullCode = table.concat(codeParts)
        local rand = randomString(10)
        local filename = (playbackMode == "Once" and "v23_coil_once_" or "v23_coil_loop_") .. rand .. ".lua"

        if writefile then
            writefile(filename, fullCode)
            b.Text = "Exported! (" .. #frames .. "f)"
            progressLabel.Text = "Saved as " .. filename
        else
            b.Text = "writefile not supported"
        end

        task.wait(3)
        b.Text = "Export Combined (Coil Fixed - Exact Walk)"
        progressLabel.Text = "Progress: Ready"
    end)
end)

-- === RECORDER (sekarang simpan hrpCFrame juga) ===
local lt = tick()
RunService.Heartbeat:Connect(function()
    if not isRecording then return end
    local char = lp.Character
    if not char then return end
    local hum = char:FindFirstChild("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    local cam = workspace.CurrentCamera
    if not (hum and root and cam) then return end

    local now = tick()
    local dt = now - lt
    if dt < 0.001 then return end
    lt = now

    table.insert(frames, {
        Pos = root.Position,
        Vel = root.AssemblyLinearVelocity,
        Move = hum.MoveDirection,
        CFrame = cam.CFrame,
        hrpCFrame = root.CFrame,          -- <-- ini yang baru (exact karakter orientation)
        FOV = cam.FieldOfView,
        Time = (#frames == 0 and 0 or frames[#frames].Time + dt),
        WalkSpeed = hum.WalkSpeed
    })
    status.Text = "Frames: " .. #frames
end)

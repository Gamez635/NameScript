local function randomString(length)
    length = length or 8
    local chars = "abcdefghijklmnopqrstuvwxyz"
    local result = ""
    for i = 1, length do
        result = result .. chars:sub(math.random(1, #chars), math.random(1, #chars))
    end
    return result
end


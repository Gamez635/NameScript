createBtn("Export Combined (Fixed)", Color3.fromRGB(100, 255, 100), function(b)
    if #frames < 50 then
        b.Text = "Too few frames!"
        task.wait(1.5)
        b.Text = "Export Combined (Fixed)"
        return
    end
    b.Text = "Building... (" .. #frames .. "f)"
    progressLabel.Text = "Progress: 0%"
    task.spawn(function()
        local codeParts = {}
        table.insert(codeParts, [[
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local cam = workspace.CurrentCamera
local char = lp.Character or lp.CharacterAdded:Wait()
local hrp = char:WaitForChild("HumanoidRootPart")
local hum = char:WaitForChild("Humanoid")
hum.AutoRotate = false
cam.CameraType = Enum.CameraType.Scriptable
local frames = {
]])
        local total = #frames
        for i, f in ipairs(frames) do
            local entry = string.format(
                "{Pos=Vector3.new(%.3f,%.3f,%.3f),Vel=Vector3.new(%.3f,%.3f,%.3f),Move=Vector3.new(%.3f,0,%.3f),CFrame=%s,FOV=%.2f,Time=%.4f}%s\n",
                f.Pos.X, f.Pos.Y, f.Pos.Z,
                f.Vel.X, f.Vel.Y, f.Vel.Z,
                f.Move.X, f.Move.Z,
                formatCFrame(f.CFrame),
                f.FOV or 70,
                f.Time,
                i < total and "," or ""
            )
            table.insert(codeParts, entry)
            if i % 300 == 0 then
                progressLabel.Text = "Progress: " .. math.floor((i / total) * 100) .. "%"
                task.wait()
            end
        end
        table.insert(codeParts, [[
}
local mode = "]] .. playbackMode .. [["
local t = 0
local idx = 1
local lastValidCFrame = cam.CFrame
local playbackFinished = false
local function smoothCFrame(a, b, alpha)
    local pos = a.Position:Lerp(b.Position, alpha)
    local lookA = a.LookVector
    local lookB = b.LookVector
    local upA = a.UpVector
    local upB = b.UpVector
    local look = lookA:Lerp(lookB, alpha)
    if look.Magnitude < 0.0001 then
        look = (a.LookVector + b.LookVector).Unit
    else
        look = look.Unit
    end
    local up = upA:Lerp(upB, alpha).Unit
    local right = look:Cross(up)
    if right.Magnitude < 0.0001 then
        right = look:Cross(Vector3.new(0,1,0)).Unit
    else
        right = right.Unit
    end
    up = right:Cross(look).Unit
    return CFrame.fromMatrix(pos, right, up)
end
RunService.RenderStepped:Connect(function(dt)
    if playbackFinished then return end
    t = t + dt
    local lastTime = frames[#frames].Time
    if mode == "Once" then
        if t > lastTime then
            cam.CFrame = lastValidCFrame
            playbackFinished = true
            return
        end
    end
    if mode == "Loop" then
        t = t % lastTime
    end
    while idx < #frames and t >= frames[idx + 1].Time do
        idx = idx + 1
    end
    if idx >= #frames then
        idx = 1
        if mode == "Once" then
            playbackFinished = true
            return
        end
    end
    local a = frames[idx]
    local b = frames[idx + 1] or frames[1]
    local alpha = (t - a.Time) / (b.Time - a.Time)
    alpha = math.clamp(alpha, 0, 1)
    local pos = a.Pos:Lerp(b.Pos, alpha)
    local vel = a.Vel:Lerp(b.Vel, alpha)
    local move = a.Move:Lerp(b.Move, alpha)
    local fov = a.FOV + (b.FOV - a.FOV) * alpha
    local cf = smoothCFrame(a.CFrame, b.CFrame, alpha)
    lastValidCFrame = cf
    cam.CFrame = cf
    cam.FieldOfView = fov
    local lookFlat = Vector3.new(cf.LookVector.X, 0, cf.LookVector.Z)
    if lookFlat.Magnitude > 0 then
        lookFlat = lookFlat.Unit
        hrp.CFrame = CFrame.new(pos, pos + lookFlat * 10)
    end
    hum:Move(move, true)
    hrp.AssemblyLinearVelocity = vel
end)
]])
        local fullCode = table.concat(codeParts)
        local rand = randomString(10)
        local filename
        if playbackMode == "Once" then
            filename = "v23_once_" .. rand .. ".lua"
        else
            filename = "v23_loop_" .. rand .. ".lua"
        end
        if writefile then
            writefile(filename, fullCode)
            b.Text = "Exported! (" .. #frames .. "f - " .. playbackMode .. ")"
            progressLabel.Text = "Progress: 100% - Saved as " .. filename
        else
            b.Text = "No writefile"
            progressLabel.Text = "Error: writefile not found"
        end
        task.wait(4)
        b.Text = "Export Combined (Fixed)"
        progressLabel.Text = "Progress: Ready"
    end)
end)

local lt = tick()
RunService.Heartbeat:Connect(function()
    if not isRecording then return end
    local char = lp.Character
    if not char then return end
    local hum = char:FindFirstChild("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    local cam = workspace.CurrentCamera
    if not (hum and root and cam) then return end
    local now = tick()
    local dt = now - lt
    if dt < 0.001 then return end
    lt = now
    table.insert(frames, {
        Pos = root.Position,
        Vel = root.AssemblyLinearVelocity,
        Move = hum.MoveDirection,
        CFrame = cam.CFrame,
        FOV = cam.FieldOfView,
        Time = #frames == 0 and 0 or (frames[#frames].Time + dt)
    })
    status.Text = "Frames: " .. #frames
end)

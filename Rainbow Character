local p=game:GetService("Players").LocalPlayer
local rs=game:GetService("RunService")

local charConn,colorConn

local function apply(c)
if colorConn then colorConn:Disconnect() end
colorConn=rs.RenderStepped:Connect(function()
local t=tick()*2
local col=Color3.fromHSV((t%5)/5,1,1)

for _,v in ipairs(c:GetDescendants())do
if v:IsA("BasePart")then
v.Color=col
v.Material=Enum.Material.Neon
elseif v:IsA("Decal")then
v.Color3=col
v.Transparency=0
elseif v:IsA("ShirtGraphic")then
v.Color3=col
elseif v:IsA("ParticleEmitter")then
v.Color=ColorSequence.new(col)
elseif v:IsA("Trail")then
v.Color=ColorSequence.new(col)
elseif v:IsA("Beam")then
v.Color=ColorSequence.new(col)
elseif v:IsA("Highlight")then
v.FillColor=col
v.OutlineColor=col
end
end

local hum=c:FindFirstChildOfClass("Humanoid")
if hum then
local desc=hum:GetAppliedDescription()
desc.HeadColor=col
desc.LeftArmColor=col
desc.RightArmColor=col
desc.LeftLegColor=col
desc.RightLegColor=col
desc.TorsoColor=col
pcall(function()
hum:ApplyDescription(desc)
end)
end

end)
end

local function setup()
local c=p.Character or p.CharacterAdded:Wait()

if not c:FindFirstChild("RainbowHighlight") then
local h=Instance.new("Highlight")
h.Name="RainbowHighlight"
h.FillTransparency=0.5
h.OutlineTransparency=0
h.Parent=c
end

apply(c)
end

if charConn then charConn:Disconnect() end
charConn=p.CharacterAdded:Connect(function(c)
task.wait(.2)
setup()
end)

if p.Character then
setup()
end

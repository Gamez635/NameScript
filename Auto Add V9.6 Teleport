        table.insert(codeParts, [[}

local mode = "]] .. playbackMode .. [["
local t = 0
local idx = 1
local isPlaying = true
local totalTime = frames[#frames].Time
local PAUSE_THRESHOLD = 0.1

local function smoothCFrame(a, b, alpha)
    local pos = a.Position:Lerp(b.Position, alpha)
    local look = a.LookVector:Lerp(b.LookVector, alpha).Unit
    local up = a.UpVector:Lerp(b.UpVector, alpha).Unit
    local right = look:Cross(up).Unit
    up = right:Cross(look).Unit
    return CFrame.fromMatrix(pos, right, up)
end

local conn
conn = RunService.RenderStepped:Connect(function(dt)
    if not isPlaying then return end
    
    t = t + dt

    if mode == "Once" and t >= totalTime then
        blackScreen.Visible = true
        cam.CameraType = originalCamType
        hum.AutoRotate = originalAutoRotate
        isPlaying = false
        conn:Disconnect()
        return
    end

    if mode == "Loop" then
        t = t % totalTime
    end

    while idx < #frames and t >= frames[idx + 1].Time do
        idx = idx + 1
    end

    if idx >= #frames then
        if mode == "Once" then
            blackScreen.Visible = true
            cam.CameraType = originalCamType
            hum.AutoRotate = originalAutoRotate
            isPlaying = false
            conn:Disconnect()
            return
        else
            idx = 1
            t = 0
        end
    end

    local a = frames[idx]
    local b = frames[idx + 1] or frames[1]
    local timeDiff = b.Time - a.Time

    -- BLACK SCREEN SAAT PAUSE
    if timeDiff > PAUSE_THRESHOLD then
        local pauseProgress = (t - a.Time) / timeDiff
        if pauseProgress < 1 then
            blackScreen.Visible = true
            return
        else
            blackScreen.Visible = false
        end
    else
        blackScreen.Visible = false
    end

    local alpha = timeDiff > 0 and math.clamp((t - a.Time) / timeDiff, 0, 1) or 0

    -- CAMERA TETAP SMOOTH
    cam.CFrame = smoothCFrame(a.CFrame, b.CFrame, alpha)
    cam.FieldOfView = a.FOV + (b.FOV - a.FOV) * alpha

    -- KARAKTER TELEPORT (Bukan Lerp)
    hrp.CFrame = a.hrpCFrame
    hrp.AssemblyLinearVelocity = a.Vel

    hum:Move(a.Move, true)
end)
